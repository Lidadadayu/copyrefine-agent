APP_NAME=ContentPilot
APP_ENV=dev
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./contentpilot.db

enable_llm_optimize= True
llm_provider= dashscope
has_key= True
llm_model= qwen3.7-max
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
ENABLE_LLM_OPTIMIZE=true

ENABLE_LANGGRAPH=true

EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_TIMEOUT=60
EMBEDDING_BATCH_SIZE=5